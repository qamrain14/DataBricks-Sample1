        "measures": [
          {
            "name": "Total Revenue",
            "expression": "SUM(FactSales[Revenue])",
            "formatString": "$#,##0.00"
          },
          {
            "name": "Total COGS",
            "expression": "SUM(FactSales[Cogs])",
            "formatString": "$#,##0.00"
          },
          {
            "name": "Gross Margin",
            "expression": "SUM(FactSales[GrossMargin])",
            "formatString": "$#,##0.00"
          },
          {
            "name": "Margin %",
            "expression": "DIVIDE([Gross Margin], [Total Revenue], 0)",
            "formatString": "0.0%"
          }
        ]
