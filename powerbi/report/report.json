  "pages": [
    {
      "name": "pg_executive_summary",
      "displayName": "Executive Summary",
      "displayOption": 1,
      "height": 720,
      "width": 1280,
      "objects": {},
      "visuals": [
        {
          "name": "card_total_spend",
          "visualType": "card",
          "x": 20, "y": 20, "width": 230, "height": 100,
          "config": {
            "singleVisual": {
              "visualType": "card",
              "projections": { "Values": [{ "queryRef": "FactPurchaseOrders.Total Spend" }] },
              "objects": {
                "labels": [{ "properties": { "color": { "solid": { "color": "#1B3A5C" } }, "fontSize": { "value": 28 } } }],
                "categoryLabels": [{ "properties": { "show": { "value": true }, "color": { "solid": { "color": "#6C757D" } } } }]
              }
            }
          }
        },
        {
          "name": "card_total_revenue",
          "visualType": "card",
          "x": 270, "y": 20, "width": 230, "height": 100,
          "config": {
            "singleVisual": {
              "visualType": "card",
              "projections": { "Values": [{ "queryRef": "FactSales.Total Revenue" }] }
            }
          }
        },
        {
          "name": "card_active_contracts",
          "visualType": "card",
          "x": 520, "y": 20, "width": 230, "height": 100,
          "config": {
            "singleVisual": {
              "visualType": "card",
              "projections": { "Values": [{ "queryRef": "FactContracts.Active Contracts" }] }
            }
          }
        },
        {
          "name": "card_vendor_count",
          "visualType": "card",
          "x": 770, "y": 20, "width": 230, "height": 100,
          "config": {
            "singleVisual": {
              "visualType": "card",
              "projections": { "Values": [{ "queryRef": "DimVendor.Vendor Count" }] }
            }
          }
        },
        {
          "name": "card_project_count",
          "visualType": "card",
          "x": 1020, "y": 20, "width": 230, "height": 100,
          "config": {
            "singleVisual": {
              "visualType": "card",
              "projections": { "Values": [{ "queryRef": "DimProject.Project Count" }] }
            }
          }
        },
        {
          "name": "chart_spend_trend",
          "visualType": "lineChart",
          "x": 20, "y": 140, "width": 750, "height": 280,
          "config": {
            "singleVisual": {
              "visualType": "lineChart",
              "projections": {
                "Category": [{ "queryRef": "CubeProcurementSpend.YearMonth" }],
                "Y": [{ "queryRef": "Sum(CubeProcurementSpend.TotalSpend)" }]
              }
            }
          }
        },
        {
          "name": "chart_budget_vs_actual",
          "visualType": "donutChart",
          "x": 790, "y": 140, "width": 460, "height": 280,
          "config": {
            "singleVisual": {
              "visualType": "donutChart",
              "projections": {
                "Category": [{ "queryRef": "CubeBudgetVsActual.VarianceClass" }],
                "Y": [{ "queryRef": "Sum(CubeBudgetVsActual.ActualAmount)" }]
              }
            }
          }
        },
        {
          "name": "chart_top_vendors",
          "visualType": "barChart",
          "x": 20, "y": 440, "width": 1230, "height": 260,
          "config": {
            "singleVisual": {
              "visualType": "barChart",
              "projections": {
                "Category": [{ "queryRef": "CubeProcurementSpend.VendorName" }],
                "Y": [{ "queryRef": "Sum(CubeProcurementSpend.TotalSpend)" }]
              },
              "objects": {
                "general": [{ "properties": { "topN": { "value": 10 } } }]
              }
            }
          }
        }
      ]
    },
    {
      "name": "pg_procurement_spend",
      "displayName": "Procurement Spend",
      "displayOption": 1,
      "height": 720,
      "width": 1280,
      "visuals": [
        {
          "name": "treemap_sector_spend",
          "visualType": "treemap",
          "x": 20, "y": 60, "width": 600, "height": 300,
          "config": {
            "singleVisual": {
              "visualType": "treemap",
              "projections": {
                "Group": [{ "queryRef": "CubeSpendBySector.SectorName" }],
                "Values": [{ "queryRef": "Sum(CubeSpendBySector.TotalSpend)" }]
              }
            }
          }
        },
        {
          "name": "bar_spend_by_project",
          "visualType": "stackedBarChart",
          "x": 640, "y": 60, "width": 620, "height": 300,
          "config": {
            "singleVisual": {
              "visualType": "stackedBarChart",
              "projections": {
                "Category": [{ "queryRef": "CubeProcurementSpend.ProjectName" }],
                "Y": [{ "queryRef": "Sum(CubeProcurementSpend.TotalSpend)" }],
                "Series": [{ "queryRef": "CubeProcurementSpend.VendorSector" }]
              }
            }
          }
        },
        {
          "name": "table_yoy_growth",
          "visualType": "tableEx",
          "x": 20, "y": 380, "width": 1240, "height": 300,
          "config": {
            "singleVisual": {
              "visualType": "tableEx",
              "projections": {
                "Values": [
                  { "queryRef": "CubeProcurementSpend.VendorName" },
                  { "queryRef": "Sum(CubeProcurementSpend.TotalSpend)" },
                  { "queryRef": "Sum(CubeProcurementSpend.PrevYearSpend)" },
                  { "queryRef": "Average(CubeProcurementSpend.YoyGrowthPct)" }
                ]
              }
            }
          }
        },
        {
          "name": "slicer_year",
          "visualType": "slicer",
          "x": 20, "y": 10, "width": 200, "height": 40,
          "config": { "singleVisual": { "visualType": "slicer", "projections": { "Values": [{ "queryRef": "CubeProcurementSpend.Year" }] } } }
        },
        {
          "name": "slicer_quarter",
          "visualType": "slicer",
          "x": 240, "y": 10, "width": 200, "height": 40,
          "config": { "singleVisual": { "visualType": "slicer", "projections": { "Values": [{ "queryRef": "CubeProcurementSpend.Quarter" }] } } }
        },
        {
          "name": "slicer_vendor_sector",
          "visualType": "slicer",
          "x": 460, "y": 10, "width": 200, "height": 40,
          "config": { "singleVisual": { "visualType": "slicer", "projections": { "Values": [{ "queryRef": "CubeProcurementSpend.VendorSector" }] } } }
        }
      ]
    },
    {
      "name": "pg_vendor_performance",
      "displayName": "Vendor Performance",
      "displayOption": 1,
      "height": 720,
      "width": 1280,
      "visuals": [
        {
          "name": "matrix_scorecard",
          "visualType": "pivotTable",
          "x": 20, "y": 60, "width": 760, "height": 360,
          "config": {
            "singleVisual": {
              "visualType": "pivotTable",
              "projections": {
                "Rows": [{ "queryRef": "CubeVendorPerformance.VendorName" }],
                "Values": [
                  { "queryRef": "Average(CubeVendorPerformance.AvgDeliveryScore)" },
                  { "queryRef": "Average(CubeVendorPerformance.AvgQualityScore)" },
                  { "queryRef": "Average(CubeVendorPerformance.AvgCommercialScore)" },
                  { "queryRef": "Average(CubeVendorPerformance.AvgHseScore)" },
                  { "queryRef": "Average(CubeVendorPerformance.AvgOverallScore)" }
                ]
              }
            }
          }
        },
        {
          "name": "pie_risk_tier",
          "visualType": "pieChart",
          "x": 800, "y": 60, "width": 460, "height": 320,
          "config": {
            "singleVisual": {
              "visualType": "pieChart",
              "projections": {
                "Category": [{ "queryRef": "CubeVendorRisk.RiskTier" }],
                "Y": [{ "queryRef": "Count(CubeVendorRisk.VendorId)" }]
              }
            }
          }
        },
        {
          "name": "scatter_risk",
          "visualType": "scatterChart",
          "x": 20, "y": 440, "width": 1240, "height": 260,
          "config": {
            "singleVisual": {
              "visualType": "scatterChart",
              "projections": {
                "X": [{ "queryRef": "CubeVendorRisk.AvgOverallScore" }],
                "Y": [{ "queryRef": "CubeVendorRisk.CompositeRiskScore" }],
                "Size": [{ "queryRef": "Sum(CubeVendorRisk.TotalInvoiced)" }],
                "Details": [{ "queryRef": "CubeVendorRisk.VendorName" }]
              }
            }
          }
        }
      ]
