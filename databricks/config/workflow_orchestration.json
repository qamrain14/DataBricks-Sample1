{
  "name": "procurement_lakehouse_workflow",
  "description": "End-to-end orchestration for Construction & Oil/Gas Procurement Lakehouse",
  "max_concurrent_runs": 1,
  "timeout_seconds": 7200,
  "schedule": {
    "quartz_cron_expression": "0 0 6 * * ?",
    "timezone_id": "Asia/Riyadh",
    "pause_status": "PAUSED"
  },
  "email_notifications": {
    "on_failure": [],
    "on_success": [],
    "no_alert_for_skipped_runs": true
  },
  "tasks": [
    {
      "task_key": "uc_setup",
      "description": "Create Unity Catalog objects (catalog, schemas, volume)",
      "sql_task": {
        "file": {
          "path": "/Workspace/procurement/databricks/setup/00_uc_setup.sql"
        },
        "warehouse_id": "{{WAREHOUSE_ID}}"
      },
      "timeout_seconds": 300
    },
    {
      "task_key": "bronze_pipeline",
      "description": "Ingest raw CSV/Excel files into Bronze Delta tables",
      "depends_on": [
        { "task_key": "uc_setup" }
      ],
      "pipeline_task": {
        "pipeline_id": "{{BRONZE_PIPELINE_ID}}",
        "full_refresh": false
      },
      "timeout_seconds": 1800
    },
    {
      "task_key": "silver_pipeline",
      "description": "Cleanse, deduplicate, type-cast into Silver layer",
      "depends_on": [
        { "task_key": "bronze_pipeline" }
      ],
      "pipeline_task": {
        "pipeline_id": "{{SILVER_PIPELINE_ID}}",
        "full_refresh": false
      },
      "timeout_seconds": 1800
    },
    {
      "task_key": "gold_pipeline",
      "description": "Build star schema (SCD2 dims + fact tables) in Gold layer",
      "depends_on": [
        { "task_key": "silver_pipeline" }
      ],
      "pipeline_task": {
        "pipeline_id": "{{GOLD_PIPELINE_ID}}",
        "full_refresh": false
      },
      "timeout_seconds": 1800
    },
    {
      "task_key": "cube_procurement_spend",
      "depends_on": [{ "task_key": "gold_pipeline" }],
      "sql_task": { "file": { "path": "/Workspace/procurement/databricks/cubes/01_cube_procurement_spend.sql" }, "warehouse_id": "{{WAREHOUSE_ID}}" },
      "timeout_seconds": 600
    },
    {
      "task_key": "cube_vendor_performance",
      "depends_on": [{ "task_key": "gold_pipeline" }],
      "sql_task": { "file": { "path": "/Workspace/procurement/databricks/cubes/02_cube_vendor_performance.sql" }, "warehouse_id": "{{WAREHOUSE_ID}}" },
      "timeout_seconds": 600
    },
    {
      "task_key": "cube_contract_status",
      "depends_on": [{ "task_key": "gold_pipeline" }],
      "sql_task": { "file": { "path": "/Workspace/procurement/databricks/cubes/03_cube_contract_status.sql" }, "warehouse_id": "{{WAREHOUSE_ID}}" },
      "timeout_seconds": 600
    },
    {
      "task_key": "cube_invoice_aging",
      "depends_on": [{ "task_key": "gold_pipeline" }],
      "sql_task": { "file": { "path": "/Workspace/procurement/databricks/cubes/04_cube_invoice_aging.sql" }, "warehouse_id": "{{WAREHOUSE_ID}}" },
      "timeout_seconds": 600
    },
    {
      "task_key": "cube_project_costs",
      "depends_on": [{ "task_key": "gold_pipeline" }],
      "sql_task": { "file": { "path": "/Workspace/procurement/databricks/cubes/05_cube_project_costs.sql" }, "warehouse_id": "{{WAREHOUSE_ID}}" },
      "timeout_seconds": 600
    },
    {
      "task_key": "cube_goods_receipt_quality",
      "depends_on": [{ "task_key": "gold_pipeline" }],
      "sql_task": { "file": { "path": "/Workspace/procurement/databricks/cubes/06_cube_goods_receipt_quality.sql" }, "warehouse_id": "{{WAREHOUSE_ID}}" },
      "timeout_seconds": 600
    },
    {
      "task_key": "cube_budget_vs_actual",
      "depends_on": [{ "task_key": "gold_pipeline" }],
      "sql_task": { "file": { "path": "/Workspace/procurement/databricks/cubes/07_cube_budget_vs_actual.sql" }, "warehouse_id": "{{WAREHOUSE_ID}}" },
      "timeout_seconds": 600
    },
    {
      "task_key": "cube_sales_analysis",
      "depends_on": [{ "task_key": "gold_pipeline" }],
      "sql_task": { "file": { "path": "/Workspace/procurement/databricks/cubes/08_cube_sales_analysis.sql" }, "warehouse_id": "{{WAREHOUSE_ID}}" },
      "timeout_seconds": 600
    },
    {
      "task_key": "cube_inventory_status",
      "depends_on": [{ "task_key": "gold_pipeline" }],
      "sql_task": { "file": { "path": "/Workspace/procurement/databricks/cubes/09_cube_inventory_status.sql" }, "warehouse_id": "{{WAREHOUSE_ID}}" },
      "timeout_seconds": 600
    },
    {
      "task_key": "cube_spend_by_sector",
      "depends_on": [{ "task_key": "gold_pipeline" }],
      "sql_task": { "file": { "path": "/Workspace/procurement/databricks/cubes/10_cube_spend_by_sector.sql" }, "warehouse_id": "{{WAREHOUSE_ID}}" },
      "timeout_seconds": 600
    },
    {
      "task_key": "cube_delivery_performance",
      "depends_on": [{ "task_key": "gold_pipeline" }],
      "sql_task": { "file": { "path": "/Workspace/procurement/databricks/cubes/11_cube_delivery_performance.sql" }, "warehouse_id": "{{WAREHOUSE_ID}}" },
      "timeout_seconds": 600
    },
    {
      "task_key": "cube_cost_variance",
      "depends_on": [{ "task_key": "gold_pipeline" }],
      "sql_task": { "file": { "path": "/Workspace/procurement/databricks/cubes/12_cube_cost_variance.sql" }, "warehouse_id": "{{WAREHOUSE_ID}}" },
      "timeout_seconds": 600
    },
    {
      "task_key": "cube_vendor_risk",
      "depends_on": [{ "task_key": "gold_pipeline" }],
      "sql_task": { "file": { "path": "/Workspace/procurement/databricks/cubes/13_cube_vendor_risk.sql" }, "warehouse_id": "{{WAREHOUSE_ID}}" },
      "timeout_seconds": 600
    },
    {
      "task_key": "cube_project_timeline",
      "depends_on": [{ "task_key": "gold_pipeline" }],
      "sql_task": { "file": { "path": "/Workspace/procurement/databricks/cubes/14_cube_project_timeline.sql" }, "warehouse_id": "{{WAREHOUSE_ID}}" },
      "timeout_seconds": 600
    },
    {
      "task_key": "cube_procurement_efficiency",
      "depends_on": [{ "task_key": "gold_pipeline" }],
      "sql_task": { "file": { "path": "/Workspace/procurement/databricks/cubes/15_cube_procurement_efficiency.sql" }, "warehouse_id": "{{WAREHOUSE_ID}}" },
      "timeout_seconds": 600
    }
  ],
  "tags": {
    "project": "procurement_lakehouse",
    "environment": "dev",
    "team": "data-engineering"
  },
  "format": "MULTI_TASK"
}
