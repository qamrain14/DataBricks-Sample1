# Environment Variables for DataBricks-Sample1
# Copy this file to .env.local and update with your values

# Databricks Workspace Configuration (update when you have access)
# DATABRICKS_HOST=https://adb-xxxxxxxxxxxx.x.azuredatabricks.net
# DATABRICKS_TOKEN=your-personal-access-token

# Local Spark Configuration
SPARK_HOME=
PYSPARK_PYTHON=python
PYSPARK_DRIVER_PYTHON=python

# Application Settings
APP_ENV=local
LOG_LEVEL=INFO
DATA_PATH=./data
OUTPUT_PATH=./data/output

# Catalog and Schema (for Unity Catalog)
DEFAULT_CATALOG=main
DEFAULT_SCHEMA=default
